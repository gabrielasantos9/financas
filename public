// Service worker mínimo: torna o app instalável (requisito técnico dos navegadores)
// e dá uma camada básica de resiliência, tentando a rede primeiro e caindo pro cache
// quando estiver offline. Isso não é cache completo de todos os arquivos — pra isso,
// no futuro dá pra evoluir usando uma ferramenta como o vite-plugin-pwa.

const CACHE_NAME = 'minhas-financas-v1'

self.addEventListener('install', () => {
  self.skipWaiting()
})

self.addEventListener('activate', (event) => {
  event.waitUntil(self.clients.claim())
})

self.addEventListener('fetch', (event) => {
  if (event.request.method !== 'GET') return

  event.respondWith(
    fetch(event.request)
      .then((resposta) => {
        const copia = resposta.clone()
        caches.open(CACHE_NAME).then((cache) => cache.put(event.request, copia))
        return resposta
      })
      .catch(() => caches.match(event.request))
  )
})
